# InstantDB
NEXT_PUBLIC_INSTANT_APP_ID=
INSTANT_ADMIN_TOKEN=

# Deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=  # Required: enables short-lived scoped keys (never exposes the main key)

# Rock RMS
ROCK_BASE_URL=
ROCK_API_KEY=
ROCK_CONTENT_CHANNEL_ID=

# Rock OIDC (OpenID Connect)
ROCK_OIDC_BASE_URL=  # e.g. https://your-rock-instance.example.com/Auth
ROCK_CLIENT_ID=
ROCK_CLIENT_SECRET=

# Auth
AUTH_SECRET=  # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROCK_AUTH_GROUP_ID=2  # Rock security group whose active members may log in

